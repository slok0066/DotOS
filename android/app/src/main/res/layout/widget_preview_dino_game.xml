            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="TAP TO START" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
        </LinearLayout>
        
