    <FrameLayout android:layout_width="8dp" android:layout_height="8dp" android:layout_gravity="top|end" android:background="#D71921" />
    
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="center" android:orientation="vertical" android:gravity="center">
