<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:typeface="monospace"

        android:text="WEEK VIEW"
        android:textColor="#999999"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginTop="20dp"
        android:gravity="center_horizontal"
        android:orientation="horizontal">

        <LinearLayout android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center">
            <TextView android:text="MON" android:textColor="#666666" android:textSize="10sp" android:typeface="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:text="11" android:textColor="#999999" android:textSize="28sp" android:textStyle="bold" android:typeface="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center">
            <TextView android:text="TUE" android:textColor="#666666" android:textSize="10sp" android:typeface="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:text="12" android:textColor="#999999" android:textSize="28sp" android:textStyle="bold" android:typeface="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center">
            <TextView android:text="WED" android:textColor="#666666" android:textSize="10sp" android:typeface="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:text="13" android:textColor="#999999" android:textSize="28sp" android:textStyle="bold" android:typeface="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center">
            <TextView android:text="THU" android:textColor="#666666" android:textSize="10sp" android:typeface="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:text="14" android:textColor="#FFFFFF" android:textSize="36sp" android:textStyle="bold" android:typeface="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/widget_preview_outline" android:gravity="center" android:padding="4dp" />
        </LinearLayout>

        <LinearLayout android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center">
            <TextView android:text="FRI" android:textColor="#666666" android:textSize="10sp" android:typeface="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:text="15" android:textColor="#999999" android:textSize="28sp" android:textStyle="bold" android:typeface="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center">
            <TextView android:text="SAT" android:textColor="#666666" android:textSize="10sp" android:typeface="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:text="16" android:textColor="#999999" android:textSize="28sp" android:textStyle="bold" android:typeface="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center">
            <TextView android:text="SUN" android:textColor="#666666" android:textSize="10sp" android:typeface="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:text="17" android:textColor="#999999" android:textSize="28sp" android:textStyle="bold" android:typeface="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:typeface="monospace"
        android:text="MAY 2026"
        android:textColor="#999999"
        android:textSize="12sp" />
</RelativeLayout>
