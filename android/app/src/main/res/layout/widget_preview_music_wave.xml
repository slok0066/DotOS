<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111"
    android:padding="16dp">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:text="NOW PLAYING"
        android:textColor="#999999"
        android:textSize="10sp" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:fontFamily="sans-serif-light"
        android:text="Awesome Track"
        android:textColor="#FFFFFF"
        android:textSize="20sp" />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_centerInParent="true"
        android:gravity="bottom"
        android:orientation="horizontal">
        <View android:layout_width="8dp" android:layout_height="30dp" android:background="#D71921" android:layout_marginEnd="4dp"/>
        <View android:layout_width="8dp" android:layout_height="50dp" android:background="#D71921" android:layout_marginEnd="4dp"/>
        <View android:layout_width="8dp" android:layout_height="20dp" android:background="#D71921" android:layout_marginEnd="4dp"/>
        <View android:layout_width="8dp" android:layout_height="40dp" android:background="#D71921" android:layout_marginEnd="4dp"/>
    </LinearLayout>
    <ProgressBar
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="24dp"
        android:max="100"
        android:progress="45"
        android:progressTint="#D71921" />
</RelativeLayout>